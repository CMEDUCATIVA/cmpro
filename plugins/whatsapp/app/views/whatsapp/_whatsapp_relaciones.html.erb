<div class="wa-chat-edit-row wa-wp-create-block">
  <div class="wa-chat-edit-field wa-chat-edit-full">
  </div>
</div>

<div class="wa-chat-edit-row wa-wp-related-block">
  <div class="wa-chat-edit-field wa-chat-edit-full">
<div class="wa-wp-related-title wa-wp-related-title-underline">Paquete de trabajo relacionado</div>
    <div class="wa-wp-related-list" data-wa-wp-related-list>
      <div class="wa-wp-related-empty">Sin paquetes relacionados.</div>
    </div>
  </div>
</div>

<div class="wa-chat-edit-row wa-wp-boards-block">
  <div class="wa-chat-edit-field wa-chat-edit-full">
    <div class="wa-wp-related-title wa-wp-related-title-underline">Tableros relacionados</div>
    <div class="wa-wp-boards-row wa-wp-boards-row-single">
      <div class="wa-wp-boards-col">
        <label class="wa-settings-label wa-wp-inline-label">Paquetes relacionados</label>
        <select class="wa-settings-input wa-wp-related-select" data-wa-wp-related-select>
          <option value="">Seleccione paquete relacionado</option>
        </select>
      </div>
      <div class="wa-wp-boards-col">
        <label class="wa-settings-label wa-wp-inline-label">Tableros</label>
        <select class="wa-settings-input wa-wp-boards-select" data-wa-board-select>
          <option value="">Seleccione tablero</option>
        </select>
      </div>
      <div class="wa-wp-boards-col">
        <label class="wa-settings-label wa-wp-inline-label">Listas / columnas</label>
        <select class="wa-settings-input wa-wp-board-list-select" data-wa-board-list-select>
          <option value="">Seleccione lista</option>
        </select>
      </div>
      <div class="wa-wp-boards-col wa-wp-boards-action">
        <button class="wa-settings-button wa-wp-board-add" type="button" data-wa-board-add>
          Añadir nueva tarjeta
        </button>
      </div>
    </div>
    <div class="wa-wp-boards-status" data-wa-board-status></div>
    <div class="wa-wp-related-list wa-wp-board-added-list" data-wa-board-added-list>
      <div class="wa-wp-related-empty">Sin tarjetas añadidas.</div>
    </div>
  </div>
</div>

<div class="wa-wp-divider" aria-hidden="true"></div>
