<% content_for :header_tags do %>
  <%= javascript_include_tag "chat", plugin: "openproject-whatsapp", nonce: true, data: { turbo_track: "reload" } %>
  <%= javascript_include_tag "openproject-whatsapp-countries", plugin: "openproject-whatsapp", nonce: true, data: { turbo_track: "reload" } %>
  <%= javascript_include_tag "wa-debug", plugin: "openproject-whatsapp", nonce: true, data: { turbo_track: "reload" } %>
  <%= javascript_include_tag "responsable_wa_chat_card", plugin: "openproject-whatsapp", nonce: true, data: { turbo_track: "reload" } %>
  <%= javascript_include_tag "conversation_selector", plugin: "openproject-whatsapp", nonce: true, data: { turbo_track: "reload" } %>
  <%= javascript_include_tag "openproject-whatsapp", plugin: "openproject-whatsapp", nonce: true, data: { turbo_track: "reload" } %>
  <%= javascript_include_tag "whatsapp_relaciones", plugin: "openproject-whatsapp", nonce: true, data: { turbo_track: "reload" } %>
