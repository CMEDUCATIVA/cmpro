<% end %>
<% if respond_to?(:action_cable_meta_tag) %>
  <%= action_cable_meta_tag %>
<% end %>
<div class="wa-shell"
     data-wa-project-id="<%= @project.id %>"
     data-wa-chat-read-url-template="<%= whatsapp_plugin_project_whatsapp_chat_read_path(@project, id: "__ID__") %>"
     data-wa-debug-log-url="<%= whatsapp_plugin_project_whatsapp_debug_path(@project) %>"
     data-contacto-table-settings-url="<%= whatsapp_plugin_project_contactos_table_settings_path(@project) %>"
     data-wa-tags="<%= ERB::Util.html_escape(@tag_map.to_json) %>"
     data-wa-tags-upsert-url="<%= whatsapp_plugin_project_contactos_tags_upsert_path(@project) %>"
     data-wa-tags-color-url="<%= whatsapp_plugin_project_contactos_tags_color_path(@project, "__ID__") %>"
     data-wa-tags-rename-url="<%= whatsapp_plugin_project_contactos_tags_rename_path(@project, "__ID__") %>"
     data-wa-tags-destroy-url="<%= whatsapp_plugin_project_contactos_tags_destroy_path(@project, "__ID__") %>"
     data-wa-tags-admin="<%= @tags_admin %>"
     data-wa-wp-types-url="<%= whatsapp_plugin_project_whatsapp_work_package_types_path(@project) %>"
     data-wa-wp-create-url="<%= whatsapp_plugin_project_whatsapp_work_packages_path(@project) %>"
     data-wa-wp-related-url="<%= whatsapp_plugin_project_whatsapp_related_work_packages_path(@project) %>"
     data-wa-wp-delete-url="<%= whatsapp_plugin_project_whatsapp_work_package_destroy_path(@project, id: "__ID__") %>"
     data-wa-wp-unlink-url="<%= whatsapp_plugin_project_whatsapp_work_package_unlink_path(@project, id: "__ID__") %>"
     data-wa-wp-statuses-url-template="<%= whatsapp_plugin_project_whatsapp_work_package_statuses_path(@project, id: "__ID__") %>"
     data-wa-boards-url="<%= whatsapp_plugin_project_whatsapp_boards_path(@project) %>"
     data-wa-board-lists-url="<%= whatsapp_plugin_project_whatsapp_board_lists_path(@project, id: "__ID__") %>"
     data-wa-board-add-url="<%= whatsapp_plugin_project_whatsapp_board_add_card_path(@project) %>"
     data-wa-board-cards-url="<%= whatsapp_plugin_project_whatsapp_board_cards_path(@project) %>"
     data-wa-board-card-delete-url="<%= whatsapp_plugin_project_whatsapp_board_card_destroy_path(@project, id: "__ID__") %>"
     data-wa-media-files-url="<%= whatsapp_plugin_project_whatsapp_media_files_path(@project) %>"
     data-wa-media-file-delete-url-template="<%= whatsapp_plugin_project_whatsapp_media_file_destroy_path(@project, id: "__ID__") %>"
     data-wa-media-files-bulk-delete-url="<%= whatsapp_plugin_project_whatsapp_media_files_bulk_destroy_path(@project) %>"
     data-wa-macros-list-url="<%= whatsapp_plugin_project_email_flows_list_path(@project, macros_only: 1) %>"
     data-wa-macros-run-url="<%= whatsapp_plugin_project_email_flows_run_path(@project) %>"
     data-wa-ia-flows-list-url="<%= whatsapp_plugin_project_email_flows_list_path(@project, ia_only: 1) %>"
     data-wa-ia-flow-select-url-template="<%= whatsapp_plugin_project_whatsapp_chat_ia_flow_path(@project, id: "__ID__") %>"
     data-wa-contact-profile-url="<%= whatsapp_plugin_project_whatsapp_contact_profile_path(@project) %>"
     data-wa-responsible-options="<%= ERB::Util.html_escape(@wa_responsible_options.to_json) %>"
     data-wa-responsible-admin="<%= User.current.admin? ? "true" : "false" %>">

  <div class="wa-content-header">
    <div class="wa-header-company">
      EMPRESA: <%= @project_settings&.session_name.to_s.upcase.presence || "-" %>
    </div>
    <button class="wa-icon-btn wa-plus-btn" type="button" title="Nuevo chat" data-wa-newchat-toggle="true">&#x271A;</button>
    <div class="wa-header-more">
      <button class="wa-icon-btn wa-header-more-btn" type="button" title="Mas acciones" aria-label="Mas acciones" data-wa-header-more-toggle="true">&#x22EE;</button>
      <div class="wa-header-more-menu is-hidden" data-wa-header-more-menu>
        <button class="wa-header-more-item" type="button" data-wa-header-action="connections">Conexiones</button>
        <button class="wa-header-more-item" type="button" data-wa-header-action="templates">Plantillas</button>
        <button class="wa-header-more-item" type="button" data-wa-header-action="files">Archivos</button>
        <% if User.current&.admin? %>
          <button class="wa-header-more-item" type="button" data-wa-header-action="server">Servidor</button>
          <button class="wa-header-more-item" type="button" data-wa-header-action="debug">Debug</button>
        <% end %>
      </div>
    </div>
    <div class="wa-qr-connected is-hidden wa-qr-connected-header" data-wa-qr-connected-header>
      <span class="wa-qr-connected-total" data-wa-qr-connected-total><%= number_to_human_size(@total_project_media_bytes || 0) %></span>
      <span class="wa-qr-connected-dot" aria-hidden="true"></span>
      <span data-wa-qr-connected-header-label>Desconectado</span>
    </div>
  </div>
  <div class="wa-new-chat-panel is-hidden" data-wa-newchat-panel>
    <div class="wa-new-chat-header">
      <div class="wa-new-chat-title">Crear un nuevo chat</div>
      <button class="wa-new-chat-close" type="button" title="Cerrar" data-wa-newchat-close="true">&#x2715;</button>
    </div>
    <label class="wa-settings-label" for="wa-newchat-from">De donde escribir</label>
    <select id="wa-newchat-from" class="wa-settings-input" data-wa-newchat-from></select>
    <label class="wa-settings-label" for="wa-newchat-phone">A donde escribir</label>
    <div class="wa-new-chat-phone">
      <div class="wa-new-chat-country-wrap">
        <input class="wa-new-chat-country-input"
               type="text"
               aria-label="Pais"
               data-wa-country-input />
        <div class="wa-new-chat-country-list is-hidden" data-wa-country-list>
        </div>
      </div>
      <input id="wa-newchat-phone" class="wa-settings-input wa-new-chat-input" type="text" placeholder="Numero" />
    </div>
    <button class="wa-settings-button wa-new-chat-submit" type="button" data-wa-newchat-create="true">Crear chat</button>
    <div class="wa-new-chat-status" data-wa-newchat-status></div>
  </div>

  <div class="wa-alert is-hidden" data-wa-alert>
    <div class="wa-alert-card">
      <div class="wa-alert-title">Advertencia</div>
      <div class="wa-alert-text" data-wa-alert-text>Este chat ya existe.</div>
      <button class="wa-settings-button wa-alert-close" type="button" data-wa-alert-close="true">Aceptar</button>
    </div>
  </div>

  <div class="wa-image-lightbox is-hidden" data-wa-image-lightbox>
    <div class="wa-image-lightbox-card">
      <button class="wa-image-lightbox-close" type="button" aria-label="Cerrar" data-wa-image-lightbox-close="true">&#x2715;</button>
      <img class="wa-image-lightbox-img" alt="Imagen" data-wa-image-lightbox-img>
      <video class="wa-image-lightbox-video" controls data-wa-image-lightbox-video></video>
    </div>
  </div>

  <div class="wa-confirm-overlay is-hidden" data-wa-confirm-overlay>
    <div class="wa-confirm-card" role="dialog" aria-modal="true">
      <div class="wa-confirm-title">Â¿EstÃ¡s seguro que deseas eliminar?</div>
      <div class="wa-confirm-actions">
        <button class="wa-confirm-yes" type="button" data-wa-confirm="yes">Si</button>
        <button class="wa-confirm-no" type="button" data-wa-confirm="no">No</button>
      </div>
    </div>
  </div>

  <main class="wa-layout">
    <aside class="wa-sidebar">
      <div class="wa-search">
        <div class="wa-search-field">
          <input type="text"
                 name="wa-chat-search"
                 role="searchbox"
                 inputmode="search"
                 placeholder="Buscar chats o personas..."
                 autocomplete="off"
                 readonly
                 aria-autocomplete="none"
                 spellcheck="false"
                 autocapitalize="off"
                 autocorrect="off"
                 data-form-type="other"
                 data-lpignore="true"
                 data-1p-ignore="true"
                 data-bwignore="true"
                 data-wa-chat-search="true"
                 data-wa-chat-search-url="<%= whatsapp_plugin_project_whatsapp_chats_search_path(@project) %>" />
          <button class="wa-search-filter-btn" type="button" aria-label="Filtros avanzados" title="Filtros avanzados" data-wa-filter-toggle>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-filter" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M6 10.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3a.5.5 0 0 1-.5-.5m-2-3a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5m-2-3a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1-.5-.5"/>
            </svg>
          </button>
        </div>
        <div class="wa-filter-panel is-hidden" data-wa-filter-panel>
          <div class="wa-filter-section">
            <div class="wa-filter-title">Estado</div>
            <% (@wp_statuses || []).each do |status| %>
              <label class="wa-filter-option">
                <input type="checkbox" value="<%= status.id %>" data-wa-filter-status>
                <%= status.name.to_s %>
              </label>
            <% end %>
          </div>
          <div class="wa-filter-section">
            <div class="wa-filter-title">Etiquetas</div>
            <div class="wa-filter-tags" data-wa-filter-tags></div>
          </div>
          <div class="wa-filter-save"></div>
        </div>
      </div>
      <div class="wa-tabs">
        <button class="wa-tab is-active" type="button" data-wa-filter="all">Todos</button>
        <button class="wa-tab" type="button" data-wa-filter="unread">No leidos</button>
        <button class="wa-tab" type="button" data-wa-filter="favorites" aria-label="Favoritos" title="Favoritos">
          <span class="wa-tab-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star" viewBox="0 0 16 16">
              <path d="M2.866 14.85c-.078.444.36.791.746.593l4.39-2.256 4.389 2.256c.386.198.824-.149.746-.592l-.83-4.73 3.522-3.356c.33-.314.16-.888-.282-.95l-4.898-.696L8.465.792a.513.513 0 0 0-.927 0L5.354 5.12l-4.898.696c-.441.062-.612.636-.282.95l3.522 3.356-.83 4.73z"/>
            </svg>
          </span>
        </button>
      </div>
      <div class="wa-filter-saved" data-wa-filter-saved></div>
      <div class="wa-chat-list" data-wa-chat-offset="<%= @chats.size %>" data-wa-chat-limit="20">
        <% @chats.each do |chat| %>
          <% initials = chat.title.to_s.split.map { |word| word[0] }.join[0, 2].to_s.upcase %>
          <% display_title = chat.title.to_s %>
          <% display_title = display_title.length > 15 ? "#{display_title[0, 15]}..." : display_title %>
          <% active_class = @active_chat && chat.id == @active_chat.id ? " is-active" : "" %>
          <% last_message = chat.messages.max_by(&:created_at) %>
          <% profile = chat.contact_profile %>
          <% phone_label = profile&.phone.to_s.strip.presence %>
          <% phone_label ||= "+#{chat.external_id.to_s.split('@').first}" if chat.external_id.to_s.present? %>
          <% preview = last_message&.body.to_s %>
          <% preview = preview.present? ? (preview.length > 15 ? "#{preview[0, 15]}..." : preview) : "Sin mensajes" %>
          <% time_label = format_time(chat.last_message_at || chat.created_at) %>
          <% favorite_class = chat.respond_to?(:favorite) && chat.favorite ? " is-favorite" : "" %>
          <% ia_flow_id = chat.metadata.is_a?(Hash) ? chat.metadata["ia_flow_id"].to_s.presence : nil %>
          <% conversation_status = (chat.metadata.is_a?(Hash) ? chat.metadata["conversation_status"].to_s : "").presence || "started" %>
          <div class="wa-chat-card<%= active_class %><%= favorite_class %>" data-chat-id="<%= chat.id %>" data-chat-external-id="<%= chat.external_id.to_s %>" data-ia-flow-id="<%= ia_flow_id.to_s %>" data-conversation-status="<%= conversation_status %>">
            <%= link_to whatsapp_plugin_project_whatsapp_path(@project, chat_id: chat.id),
                        class: "wa-chat-link",
                        data: { whatsapp_chat_link: true, chat_id: chat.id, chat_external_id: chat.external_id.to_s, turbo: false } do %>
              <div class="wa-chat-meta">
              <div class="wa-chat-row wa-chat-row-actions">
                <div class="wa-chat-actions-left">
                  <div class="wa-avatar"><%= initials.presence || "CH" %></div>
                  <div class="wa-chat-actions">
                    <button class="wa-chat-edit" type="button" title="Editar" data-wa-chat-edit-toggle="true">&#x270E;</button>
                    <button class="wa-chat-action wa-chat-action-ia" type="button" title="IA" data-wa-chat-ia="true">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-robot" viewBox="0 0 16 16">
                        <path d="M6 12.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3a.5.5 0 0 1-.5-.5M3 8.062C3 6.76 4.235 5.765 5.53 5.886a26.6 26.6 0 0 0 4.94 0C11.765 5.765 13 6.76 13 8.062v1.157a.93.93 0 0 1-.765.935c-.845.147-2.34.346-4.235.346s-3.39-.2-4.235-.346A.93.93 0 0 1 3 9.219zm4.542-.827a.25.25 0 0 0-.217.068l-.92.9a25 25 0 0 1-1.871-.183.25.25 0 0 0-.068.495c.55.076 1.232.149 2.02.193a.25.25 0 0 0 .189-.071l.754-.736.847 1.71a.25.25 0 0 0 .404.062l.932-.97a25 25 0 0 0 1.922-.188.25.25 0 0 0-.068-.495c-.538.074-1.207.145-1.98.189a.25.25 0 0 0-.166.076l-.754.785-.842-1.7a.25.25 0 0 0-.182-.135"></path>
                        <path d="M8.5 1.866a1 1 0 1 0-1 0V3h-2A4.5 4.5 0 0 0 1 7.5V8a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1v1a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-1a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1v-.5A4.5 4.5 0 0 0 10.5 3h-2zM14 7.5V13a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V7.5A3.5 3.5 0 0 1 5.5 4h5A3.5 3.5 0 0 1 14 7.5"></path>
                      </svg>
                    </button>
                    <button class="wa-chat-favorite" type="button" title="Favorito" data-wa-chat-favorite="true">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star" viewBox="0 0 16 16">
                        <path d="M2.866 14.85c-.078.444.36.791.746.593l4.39-2.256 4.389 2.256c.386.198.824-.149.746-.592l-.83-4.73 3.522-3.356c.33-.314.16-.888-.282-.95l-4.898-.696L8.465.792a.513.513 0 0 0-.927 0L5.354 5.12l-4.898.696c-.441.062-.612.636-.283.95l3.523 3.356-.83 4.73zm4.905-2.767-3.686 1.894.694-3.957a.56.56 0 0 0-.163-.505L1.71 6.745l4.052-.576a.53.53 0 0 0 .393-.288L8 2.223l1.847 3.658a.53.53 0 0 0 .393.288l4.052.575-2.906 2.77a.56.56 0 0 0-.163.506l.694 3.957-3.686-1.894a.5.5 0 0 0-.461 0z"></path>
                      </svg>
                    </button>
                  </div>
                </div>
                <div class="wa-chat-actions-right">
                  <button class="wa-chat-delete" type="button" title="Eliminar" data-wa-chat-delete="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16" aria-hidden="true">
                      <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"/>
                    </svg>
                  </button>
                  <div class="wa-chat-time"><%= time_label %></div>
                </div>
              </div>
              <div class="wa-chat-row">
                <div class="wa-chat-name-box">
                  <span class="wa-chat-title"><%= display_title.presence || "Chat" %></span>
                  <% tags = Array(profile&.tags).map { |tag| tag.to_s.strip }.reject(&:blank?) %>
                  <div class="wa-chat-tags" data-wa-chat-tags data-tags="<%= ERB::Util.html_escape(tags.to_json) %>">
                    <% if tags.any? %>
                      <% tag_map = (@tag_map || []).each_with_object({}) { |tag, acc| acc[tag[:name].to_s.downcase] = tag } %>
                      <% tags.first(4).each do |tag| %>
                        <% meta = tag_map[tag.downcase] || { color: "#1e88e5" } %>
                        <% initials = tag.split(/\s+/).map { |part| part[0] }.join("").upcase[0, 2] %>
                        <% initials = tag[0, 2].to_s.upcase if initials.blank? %>
                        <% color = meta[:color].to_s %>
                        <% light = ["#fdd835", "#ffffff", "#9e9e9e", "#ec407a", "#fb8c00"].include?(color.downcase) %>
                        <span class="wa-chat-tag-dot" draggable="true" style="background-color:<%= color %>;color:<%= light ? "#111111" : "#ffffff" %>" data-tooltip="<%= tag %>"><%= initials %></span>
                      <% end %>
                      <% if tags.size > 4 %>
                        <span class="wa-chat-tag-more" aria-hidden="true">...</span>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
              <div class="wa-chat-row">
                <div class="wa-chat-subtitle">Telefono:</div>
                <div class="wa-chat-subvalue"><%= phone_label.presence || "--" %></div>
              </div>
              <div class="wa-chat-row">
                <div class="wa-chat-subtitle">Email:</div>
                <div class="wa-chat-subvalue"><%= profile&.email.to_s.presence || "--" %></div>
              </div>
              <div class="wa-chat-preview-row">
                <div class="wa-chat-preview"><%= preview %></div>
                <% if conversation_status != "ended" && chat_unread_count(chat) > 0 %>
                  <span class="wa-unread-badge"><%= chat_unread_count(chat) %></span>
                <% end %>
              </div>
              </div>
            <% end %>
            <div class="wa-ia-panel" data-wa-ia-panel>
              <div class="wa-ia-panel-header">
              <div class="wa-ia-panel-title">AutomatizaciÃ³n e IA</div>
                <button class="wa-ia-panel-close" type="button" title="Cerrar" data-wa-ia-close="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x-square-fill" viewBox="0 0 16 16">
                    <path d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2zm3.354 4.646L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 1 1 .708-.708"></path>
                  </svg>
                </button>
              </div>
              <div class="wa-ia-panel-body">
                <div class="wa-ia-macro-row">
                  <select class="wa-chat-macro-select" data-wa-ia-macro-select="true">
                    <option value="">Seleccione macros</option>
                    <% if @macro_flows.present? %>
                      <% @macro_flows.each do |flow_item| %>
                        <option value="<%= flow_item[:id] %>" data-macro-node-id="<%= flow_item[:macro_node_id] %>">
                          <%= flow_item[:name].to_s.presence || "Flujo #{flow_item[:id]}" %>
                        </option>
                      <% end %>
                    <% end %>
                  </select>
                  <button class="wa-chat-macro-run" type="button" data-wa-ia-macro-run="true" title="Ejecutar macro" disabled>
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22ZM10.6935 15.8458L15.4137 13.059C16.1954 12.5974 16.1954 11.4026 15.4137 10.941L10.6935 8.15419C9.93371 7.70561 9 8.28947 9 9.21316V14.7868C9 15.7105 9.93371 16.2944 10.6935 15.8458Z" fill="#1C274C"></path>
                    </svg>
                  </button>
                </div>
                <div class="wa-ia-macro-row wa-ia-flow-row">
                  <select class="wa-chat-ia-select" data-wa-ia-flow-select="true">
                    <option value="">Seleccione la IA</option>
                    <% if @ia_flows.present? %>
                      <% @ia_flows.each do |flow_item| %>
                        <option value="<%= flow_item[:id] %>">
                          <%= flow_item[:name].to_s.presence || "Flujo #{flow_item[:id]}" %>
                        </option>
