    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid #e6eaee;
    cursor: pointer;
    font-size: 12px;
  }

  .wa-empty-state {
    color: var(--wa-text-soft);
    font-size: 13px;
    text-align: center;
