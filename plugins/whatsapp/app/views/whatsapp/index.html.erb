    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .wa-chat-edit-close-btn {
    background: transparent;
    color: var(--wa-text);
    width: auto;
    height: auto;
    padding: 0;
    font-size: 20px;
    font-weight: 700;
    border-radius: 0;
  }

  .wa-chat-edit-form {
    display: grid;
    gap: 12px 16px;
    grid-template-columns: 1fr;
    padding: 12px 16px 16px;
  }

  .wa-chat-edit-row {
    grid-column: 1 / -1;
    display: grid;
    gap: 12px 16px;
    grid-template-columns: 1fr;
  }

  .wa-chat-edit-row.is-single {
    grid-template-columns: 1fr;
  }

  .wa-chat-edit-form textarea.wa-settings-input {
    min-height: 80px;
    resize: vertical;
  }

  .wa-chat-edit-field {
    display: grid;
    gap: 6px;
  }

  .wa-chat-edit-field.is-hidden {
    display: none;
  }

  .wa-chat-edit-full {
    grid-column: 1 / -1;
  }

  .wa-chat-edit-actions {
    grid-column: 1 / -1;
    display: flex;
    justify-content: flex-end;
  }

  .wa-chat-edit-save {
    margin-top: 4px;
    justify-self: end;
    background: #25D366;
    color: #ffffff;
    font-family: "Plus Jakarta Sans", "Segoe UI", sans-serif;
    font-size: 14px;
    padding: 8px 10px;
    border-radius: 8px;
  }

