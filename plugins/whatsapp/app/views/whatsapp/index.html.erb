        </div>

        <div class="wa-messages" data-wa-messages="true">
          <div class="wa-day-divider wa-day-divider-floating" data-wa-day-floating>Hoy</div>
          <div class="wa-chat-media-size" data-wa-chat-media-size>
            <%= number_to_human_size(@active_chat_media_bytes || 0) %> -
            Ultimo mensaje <%= format_time_full(@active_chat&.last_message_at || @active_chat&.created_at || Time.current) %>
          </div>
          <% if @active_chat %>
            <% if @has_more_messages %>
              <button class="wa-load-more" type="button"
                      data-wa-load-more="true"
                      data-wa-load-url="<%= whatsapp_plugin_project_whatsapp_path(@project, chat_id: @active_chat.id) %>"
                      data-wa-before-id="<%= @oldest_message_id %>">
                Mostrar mas
              </button>
            <% end %>
            <% @messages.each do |message| %>
              <% outgoing = message.sender_user_id == User.current.id %>
              <% sender_label = outgoing ? "" : (message.sender_contact&.name || message.sender_user&.name || "Contacto") %>
              <% metadata = message.metadata.is_a?(Hash) ? message.metadata : {} %>
                <% reply_label = message.body.to_s.strip %>
                <% if reply_label.blank? %>
                  <% reply_label = "Imagen" if message.message_type == "image" %>
                  <% reply_label = "Video" if message.message_type == "video" %>
                  <% reply_label = "Archivo" if message.message_type == "file" %>
                <% end %>
                <% reply_label = reply_label[0, 60] + "..." if reply_label.length > 60 %>
                <% reply_to = metadata["reply_to"].presence %>
                <div class="wa-bubble <%= outgoing ? "is-out" : "is-in" %><%= message.message_type == "image" ? " is-image" : "" %><%= message.message_type == "activity" ? " is-activity" : "" %>"
                     data-message-id="<%= message.id %>"
                     data-created-at="<%= message.created_at.iso8601 %>"
                     data-waha-id="<%= metadata["waha_id"].presence %>"
                     data-reply-id="<%= metadata["waha_id"].presence || message.id %>"
                     data-reply-label="<%= reply_label %>"
                     <%= reply_to ? "data-reply-to=\"#{reply_to}\"" : "" %>>
                <div class="wa-bubble-meta"><%= format_time(message.created_at) %></div>
                <button class="wa-bubble-actions" type="button" title="Opciones" data-wa-bubble-actions="true">&#x25BE;</button>
                <div class="wa-bubble-body">
                  <% if message.message_type == "image" %>
                    <% caption = message.body.to_s %>
                    <% base64_caption = caption.start_with?("data:") || (caption.length > 2000 && caption.match?(/\A[a-zA-Z0-9+\/=\s]+\z/)) %>
                    <% content_type = metadata["content_type"].to_s %>
                    <% sticker = content_type == "image/webp" || metadata["filename"].to_s.downcase.end_with?(".webp") %>
                    <img class="wa-bubble-image<%= sticker ? " is-sticker" : "" %>"
                         data-wa-bubble-image="true"
                         data-media-id="<%= message.id %>"
                         data-full-src="<%= metadata["data_url"].presence %>"
                         data-thumb-src="<%= metadata["thumb_data_url"].presence %>"
                         data-remote-src="<%= metadata["remote_url"].presence %>"
                         src="<%= metadata["thumb_data_url"].presence || metadata["data_url"].presence || "data:image/gif;base64,R0lGODlhAQABAAAAACw=" %>"
                         loading="lazy"
                         decoding="async"
                         alt="Imagen" />
                    <% if caption.present? && !base64_caption %>
                      <div class="wa-bubble-caption"><%= wa_linkify(caption) %></div>
                    <% end %>
                  <% elsif message.message_type == "file" %>
                    <div class="wa-bubble-file">
                      <span class="wa-file-name"><%= metadata["filename"].presence || "archivo" %></span>
                      <a class="wa-file-download wa-file-icon" href="#" data-media-id="<%= message.id %>">
                        <% ext = File.extname(metadata["filename"].to_s).delete(".").upcase.presence || "FILE" %>
                        <% ext = ext[0, 4] %>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 28" width="24" height="28" aria-hidden="true">
                          <g fill="#dc2626">
                            <path d="M6 2h8l6 6v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
                            <path d="M14 2v6h6"/>
                          </g>
                          <g transform="translate(12 13)" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M0 -4v5.5 M-2.5 0l2.5 2.5 2.5-2.5"/>
                            <line x1="-4" y1="4" x2="4" y2="4"/>
                          </g>
                          <rect x="2" y="21" width="20" height="6" rx="3" fill="#dc2626"/>
                          <text x="12" y="26" text-anchor="middle" font-size="6" font-weight="700" fill="#ffffff" font-family="system-ui, -apple-system, Segoe UI, Roboto, Arial"><%= ext %></text>
                        </svg>
                      </a>
                    </div>
                    <% if message.body.present? %>
                      <div class="wa-bubble-caption"><%= wa_linkify(message.body) %></div>
                    <% end %>
                  <% elsif message.message_type == "video" %>
                    <div class="wa-bubble-file">
                      <span class="wa-file-name"><%= metadata["filename"].presence || "video.mp4" %></span>
                      <a class="wa-file-download wa-file-icon" href="#" data-media-id="<%= message.id %>">
                        <% ext = File.extname(metadata["filename"].to_s).delete(".").upcase.presence || "VIDEO" %>
                        <% ext = ext[0, 4] %>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 28" width="24" height="28" aria-hidden="true">
                          <g fill="#dc2626">
                            <path d="M6 2h8l6 6v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
                            <path d="M14 2v6h6"/>
                          </g>
                          <g transform="translate(12 13)" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M0 -4v5.5 M-2.5 0l2.5 2.5 2.5-2.5"/>
                            <line x1="-4" y1="4" x2="4" y2="4"/>
                          </g>
                          <rect x="2" y="21" width="20" height="6" rx="3" fill="#dc2626"/>
                          <text x="12" y="26" text-anchor="middle" font-size="6" font-weight="700" fill="#ffffff" font-family="system-ui, -apple-system, Segoe UI, Roboto, Arial"><%= ext %></text>
                        </svg>
                      </a>
                    </div>
                    <% if message.body.present? %>
                      <div class="wa-bubble-caption"><%= wa_linkify(message.body) %></div>
                    <% end %>
                  <% else %>
                    <%= wa_linkify(message.body) %>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>

        <%= form_with scope: :message,
                      url: whatsapp_plugin_project_whatsapp_messages_path(@project),
                      method: :post,
                      local: true,
                      data: { turbo: false, whatsapp_form: true, wa_image_send_url: whatsapp_plugin_project_whatsapp_images_path(@project), wa_video_send_url: whatsapp_plugin_project_whatsapp_videos_path(@project), wa_file_send_url: whatsapp_plugin_project_whatsapp_files_path(@project), wa_media_url_template: whatsapp_plugin_project_whatsapp_message_media_path(@project, id: "__ID__"), wa_typing_start_url: whatsapp_plugin_project_whatsapp_typing_start_path(@project), wa_typing_stop_url: whatsapp_plugin_project_whatsapp_typing_stop_path(@project), wa_activity_note_url: whatsapp_plugin_project_whatsapp_activity_note_path(@project) },
                      class: "wa-composer" do |form| %>
            <div class="wa-input-row">
              <div class="wa-input-field">
                <div class="wa-image-preview is-hidden" data-wa-image-preview>
                  <button class="wa-image-preview-close" type="button" aria-label="Cerrar" data-wa-image-cancel="true">&#x2715;</button>
                  <img class="wa-image-preview-img" alt="Vista previa" data-wa-image-preview-img>
                  <video class="wa-image-preview-video" controls data-wa-image-preview-video></video>
                  <div class="wa-file-preview" data-wa-file-preview></div>
                  <div class="wa-preview-strip" data-wa-preview-strip></div>
              </div>
              <div class="wa-reply-preview is-hidden" data-wa-reply-preview>
                <div class="wa-reply-text">
                  <strong>Respondiendo</strong>
                  <span data-wa-reply-label></span>
                </div>
                <button class="wa-reply-cancel" type="button" aria-label="Cancelar" data-wa-reply-cancel="true">&#x2715;</button>
              </div>
              <div class="wa-plus-menu is-hidden" data-wa-plus-menu>
                <button class="wa-plus-item" type="button" data-wa-plus-photo="true">Fotos y videos</button>
                <button class="wa-plus-item" type="button" data-wa-plus-doc="true">Documentos</button>
                <button class="wa-plus-item" type="button" data-wa-plus-activity="true">Actividad</button>
              </div>
              <input class="wa-plus-file"
                     type="file"
                     accept="image/*,video/*"
                     multiple="multiple"
                     data-wa-plus-file="true" />
              <input class="wa-plus-doc"
                     type="file"
                     accept="*/*"
                     multiple="multiple"
                     data-wa-plus-doc-file="true" />
                <%= hidden_field_tag :reply_to, "", data: { wa_reply_to: true } %>
                <div class="wa-input-textarea">
                  <div class="wa-input-actions">
                    <button class="wa-icon-btn wa-plus-btn" type="button" title="Opciones" data-wa-menu-toggle="true">&#x271A;</button>
                    <button class="wa-icon-btn wa-emoji-btn" type="button" title="Emoticones" data-wa-emoji-toggle="true">&#x2615;</button>
                  </div>
                  <%= form.text_area :body, rows: 2, placeholder: "Escribe un mensaje..." %>
                  <button class="wa-send-float" type="submit" title="Enviar">&#x27A4;</button>
                </div>
              </div>
            </div>
          <div class="wa-emoji-panel is-hidden wa-float-panel" aria-label="Emoticones" data-wa-emoji>
            <div class="wa-emoji-grid">
              <span>&#x1F600;</span><span>&#x1F603;</span><span>&#x1F604;</span><span>&#x1F601;</span><span>&#x1F606;</span><span>&#x1F605;</span><span>&#x1F923;</span><span>&#x1F602;</span>
              <span>&#x1F609;</span><span>&#x1F60A;</span><span>&#x1F60D;</span><span>&#x1F618;</span><span>&#x1F60E;</span><span>&#x1F60F;</span><span>&#x1F914;</span><span>&#x1F634;</span>
              <span>&#x1F644;</span><span>&#x1F62E;</span><span>&#x1F62D;</span><span>&#x1F622;</span><span>&#x1F621;</span><span>&#x1F624;</span><span>&#x1F4AA;</span><span>&#x1F44D;</span>
              <span>&#x1F44E;</span><span>&#x1F64C;</span><span>&#x1F44F;</span><span>&#x1F91D;</span><span>&#x2705;</span><span>&#x274C;</span><span>&#x2757;</span><span>&#x2753;</span>
              <span>&#x1F4CC;</span><span>&#x1F4CE;</span><span>&#x1F4C8;</span><span>&#x1F4CA;</span><span>&#x1F4A1;</span><span>&#x1F525;</span><span>&#x2728;</span><span>&#x1F389;</span>
              <span>&#x1F680;</span><span>&#x1F6A7;</span><span>&#x1F6E0;</span><span>&#x1F9F0;</span><span>&#x1F3D7;</span><span>&#x1F3D9;</span><span>&#x1F3ED;</span><span>&#x1F3E2;</span>
            </div>
          </div>
          <%= hidden_field_tag :chat_id, @active_chat&.id %>
          <div class="wa-send-row"></div>
        <% end %>
      </div>
    </section>
  </main>

  <div class="wa-debug-console" data-wa-debug-console></div>
</div>

<style>
  #content-body {
    height: 100%;
    min-height: 100%;
    overflow: hidden;
    background: var(--wa-bg);
  }

  body.wa-debug-active #content-body {
    height: auto;
    min-height: 100%;
    overflow: visible;
  }
  :root {
    --wa-bg: #f5f6f8;
    --wa-panel: #ffffff;
    --wa-panel-strong: #f2f4f6;
    --wa-card: #f7f9fb;
    --wa-accent: #25d366;
    --wa-accent-soft: rgba(37, 211, 102, 0.14);
    --wa-text: #101418;
    --wa-text-soft: #66737f;
    --wa-danger: #f97316;
    --wa-shadow: 0 18px 40px rgba(16, 24, 40, 0.12);
    --wa-radius: 18px;
  }

  .wa-shell {
    font-family: "Plus Jakarta Sans", "Segoe UI", sans-serif;
    color: var(--wa-text);
    background: var(--wa-bg);
    min-height: 100vh;
    padding: 0 0 20px 0;
    position: relative;
    overflow: hidden;
    --wa-container-height: calc(100vh - 148px);
  }

  .wa-bg-shapes::before,
  .wa-bg-shapes::after {
    content: "";
    position: absolute;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    filter: blur(0px);
    opacity: 0.18;
    background: linear-gradient(120deg, #93c5fd, #86efac);
    animation: float 16s ease-in-out infinite;
  }

  .wa-bg-shapes::before {
    top: -120px;
    right: -80px;
  }

  .wa-bg-shapes::after {
    bottom: -160px;
    left: -120px;
    animation-delay: -6s;
  }

  .wa-chat-tools {
    display: flex;
    gap: 8px;
  }

  .wa-chat-media-size {
    position: sticky;
    left: 12px;
    top: 12px;
    font-size: 12px;
    color: var(--wa-text-soft);
    background: transparent;
    padding: 4px 8px;
    border-radius: 999px;
    white-space: nowrap;
    pointer-events: none;
    z-index: 2;
  }

  .wa-chat-edit {
    border: none;
    background: #eef2f6;
    width: 26px;
    height: 26px;
    border-radius: 8px;
    cursor: pointer;
    display: grid;
    place-items: center;
    transform: none;
  }

  .wa-chat-action-ia {
    border: none;
    background: transparent;
    color: #0b141a;
    width: 26px;
    height: 26px;
    padding: 0;
    border-radius: 8px;
    cursor: pointer;
    display: grid;
    place-items: center;
  }

  .wa-content-header {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin-bottom: 6px;
    gap: 8px;
  }

  .wa-header-company {
    font-size: 14px;
    font-weight: 700;
    color: var(--wa-text);
    margin-right: 8px;
  }

  .wa-header-more {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .wa-icon-btn {
    border: none;
    background: var(--wa-panel-strong);
    color: var(--wa-text);
    width: 48px;
    height: 40px;
    border-radius: 12px;
    cursor: pointer;
    box-shadow: var(--wa-shadow);
    transition: transform 0.2s ease, background 0.2s ease;
    font-size: 12px;
  }

  .wa-gear-btn {
    width: 40px;
    font-size: 16px;
  }

  .wa-header-more-btn {
    width: 40px;
    font-size: 18px;
    line-height: 1;
  }

  .wa-icon-btn:hover {
    transform: translateY(-2px);
    background: var(--wa-card);
  }

  .wa-header-more-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 180px;
    background: #ffffff;
    border: 1px solid #dbe3ea;
    border-radius: 14px;
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.18);
    padding: 8px;
    display: grid;
    gap: 4px;
    z-index: 30;
  }

  .wa-header-more-menu.is-hidden {
