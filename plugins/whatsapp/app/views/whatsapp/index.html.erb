    position: sticky;
    bottom: 0;
    background: #ffffff;
    padding: 10px 16px;
    margin-top: 0;
    border-top: 1px solid #e6eaee;
    display: flex;
    justify-content: flex-end;
    z-index: 2;
  }

  .wa-more-item {
    border: none;
    background: #f5f7fa;
    color: var(--wa-text);
