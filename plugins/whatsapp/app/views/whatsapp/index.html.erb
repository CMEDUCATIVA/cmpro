    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.12);
  }

  .wa-bubble {
    max-width: 70%;
    padding: 10px 32px 22px 12px;
    border-radius: 16px;
    background: #ffffff;
    position: relative;
    border: 1px solid #e6eaee;
    overflow: visible;
  }

  .wa-bubble.is-image {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    min-height: 80px;
    height: auto;
    max-height: none;
    overflow: hidden;
  }

  .wa-bubble.is-out {
    align-self: flex-end;
    background: #dcf8c6;
    color: #0f1419;
    border-top-right-radius: 6px;
    border: 1px solid rgba(37, 211, 102, 0.35);
  }

  .wa-bubble.is-activity {
    background: #2563eb;
    color: #ffffff;
    border-color: #1d4ed8;
  }

  .wa-bubble.is-activity .wa-bubble-meta,
  .wa-bubble.is-activity .wa-bubble-actions {
    color: #dbeafe;
  }

  .wa-bubble.is-activity a {
    color: #bfdbfe;
  }

  .wa-bubble.is-in {
    align-self: flex-start;
    border-top-left-radius: 6px;
    margin-left: 12px;
  }

  .wa-bubble.is-uploading {
    opacity: 0.95;
  }

  .wa-bubble.is-error {
    border-color: #ef4444;
  }

  .wa-upload-progress {
    margin-top: 8px;
    height: 6px;
    background: #e6eaee;
    border-radius: 999px;
