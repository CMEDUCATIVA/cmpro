<section class="op-email-email--section" id="email-flows-history">
  <div class="op-email-email--flow-history" data-flow-global-history data-flow-history-url="<%= whatsapp_plugin_project_email_flows_history_data_path(@project) %>">
    <div class="op-email-email--flow-history-header">
      <h3>Historial de flujo</h3>
      <button type="button" class="op-email-email--button is-secondary" data-flow-history-refresh="true">Actualizar</button>
    </div>
    <div class="op-email-email--flow-history-list" data-flow-history-list>
      <div class="op-email-email--flow-history-empty">Sin ejecuciones.</div>
    </div>
  </div>
</section>
