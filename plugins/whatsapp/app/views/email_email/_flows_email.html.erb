      <label class="op-email-email--flow-modal-label" for="flow-name-input">Nombre del flujo</label>
      <input id="flow-name-input" type="text" class="op-email-email--flow-modal-input" data-flow-create-name />
      <div class="op-email-email--flow-modal-actions">
        <button type="button" class="op-email-email--button is-secondary" data-flow-create-cancel>Cancelar</button>
        <button type="button" class="op-email-email--button" data-flow-create-confirm>Crear</button>
      </div>
    </div>
  </div>

  <div class="op-email-email--flow-modal is-hidden" data-flow-rename-modal>
    <div class="op-email-email--flow-modal-card">
      <div class="op-email-email--flow-modal-title">Editar nombre</div>
