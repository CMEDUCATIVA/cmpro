  <div class="contacto-pause-modal is-hidden" data-contacto-pause-modal aria-hidden="true">
    <div class="contacto-pause-modal-backdrop" data-contacto-pause-close></div>
    <div class="contacto-pause-modal-panel" role="dialog" aria-modal="true" aria-label="Pausa breve">
      <div class="contacto-pause-modal-header">
        <div class="contacto-pause-modal-title">Pausa breve</div>
        <button type="button" class="contacto-call-modal-close" data-contacto-pause-close aria-label="Cerrar">&#x2715;</button>
      </div>
      <div class="contacto-pause-modal-body">
        <div class="contacto-pause-modal-timer" data-contacto-pause-timer>00:00:00</div>
        <div class="contacto-pause-modal-hint" data-contacto-pause-hint>Inicia para comenzar a medir tu pausa.</div>
      </div>
      <div class="contacto-pause-modal-actions">
        <button type="button" class="contacto-btn contacto-btn-ghost" data-contacto-pause-start>Iniciar</button>
        <button type="button" class="contacto-btn" data-contacto-pause-finish disabled="disabled">Finalizar</button>
      </div>
    </div>
  </div>
</div>
