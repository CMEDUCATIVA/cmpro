<%#-- copy of core rate partial with sale_rate --%>

<%- 
  templated ||= false
  index ||= "INDEX"
  new_or_existing = rate.new_record? ? "new" : "existing"
  id_or_index = rate.new_record? ? index : rate.id
  prefix = "cost_type[#{new_or_existing}_rate_attributes][]"
  id_prefix = "cost_type_#{new_or_existing}_rate_attributes_#{id_or_index}"

  @rate = rate
  error_messages = error_messages_for "rate"
-%>

<% unless error_messages.blank? %>
  <tr><td colspan="5"><%= error_messages %></td></tr>
<% end %>
<%= fields_for prefix, rate, builder: TabularFormBuilder do |rate_form| %>
  <%= content_tag(
        :tr,
        id: id_prefix,
        data: templated ? { "row-target": "true" } : {},
        style: templated ? "display: none;" : ""
      ) do %>
    <td class="-no-ellipsis">
      <label class="sr-only" for="<%= "#{id_prefix}_valid_from" %>"><%= Rate.human_attribute_name(:valid_from) %></label>
      <%= rate_form.date_picker :valid_from,
                                index: id_or_index,
                                class: "date costs-date-picker",
                                no_field_container: true,
                                no_label: true,
                                required: templated ? false : true %>
    </td>
    <td class="currency">
      <span class="inline-label">
        <label class="sr-only" for="<%= "#{id_prefix}_rate" %>"><%= t('cost_types.cost_rate_label', default: Rate.model_name.human) %></label>
        <%= rate_form.text_field :rate,
                                 size: 7,
                                 index: id_or_index,
                                 inputmode: :decimal,
                                 placeholder: t(:label_example_placeholder, decimal: unitless_currency_number(1000.50)),
                                 value: rate.rate ? unitless_currency_number(rate.rate.round(2)) : "",
                                 no_label: true,
                                 no_field_container: true,
                                 required: templated ? false : true %>
        <span class="form-label">
          <%= Setting.costs_currency %>
        </span>
      </span>
    </td>
    <td class="currency">
      <span class="inline-label">
        <label class="sr-only" for="<%= "#{id_prefix}_sale_rate" %>"><%= t('cost_types.sale_rate_label') %></label>
        <%= rate_form.text_field :sale_rate,
                                 size: 7,
                                 index: id_or_index,
                                 inputmode: :decimal,
                                 placeholder: t(:label_example_placeholder, decimal: unitless_currency_number(1000.50)),
                                 value: rate.sale_rate ? unitless_currency_number(rate.sale_rate.round(2)) : "",
                                 no_label: true,
                                 no_field_container: true,
                                 data: { "costos-decimal": true },
                                 required: templated ? false : true %>
        <span class="form-label">
          <%= Setting.costs_currency %>
        </span>
      </span>
    </td>
    <td class="currency">
      <span class="inline-label">
        <label class="sr-only" for="<%= "#{id_prefix}_study_rate" %>"><%= t('cost_types.study_rate_label') %></label>
        <%= rate_form.text_field :study_rate,
                                 size: 7,
                                 index: id_or_index,
                                 inputmode: :decimal,
                                 placeholder: t(:label_example_placeholder, decimal: unitless_currency_number(1000.50)),
                                 value: rate.study_rate ? unitless_currency_number(rate.study_rate.round(2)) : "",
                                 no_label: true,
                                 no_field_container: true,
                                 data: { "costos-decimal": true },
                                 required: templated ? false : true %>
        <span class="form-label">
          <%= Setting.costs_currency %>
        </span>
      </span>
    </td>
    <td class="buttons">
      <a href="#"
         class="delete-row-button no-decoration-on-hover"
         data-action="subform#deleteRow">
        <%= op_icon("icon-context icon-delete", title: t(:button_delete)) %>
      </a>
    </td>
  <% end %>
<% end %>
