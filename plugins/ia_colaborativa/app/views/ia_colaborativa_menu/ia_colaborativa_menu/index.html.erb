<style>
  .ia-colaborativa-menu-page {
    width: 100%;
    height: 100%;
    min-height: 0;
    margin: 0;
    padding: 2% 0;
    box-sizing: border-box;
    overflow: hidden;
  }

  .ia-colaborativa-menu-active,
  .ia-colaborativa-menu-active body,
  .ia-colaborativa-menu-active #wrapper,
  .ia-colaborativa-menu-active #content-wrapper,
  .ia-colaborativa-menu-active #content-body {
    overflow-x: hidden !important;
  }

  /* Prevent the global left-menu resizer from extending below viewport and creating bottom artifacts */
  .ia-colaborativa-menu-active op-resizer.main-menu--resizer,
  .ia-colaborativa-menu-active .main-menu--resizer {
    top: 55px !important;
    bottom: 0 !important;
    height: auto !important;
    max-height: calc(100vh - 55px) !important;
  }

  .ia-colaborativa-menu-layout {
    display: flex;
    width: 100%;
    height: 100%;
    gap: 16px;
  }

  .ia-colaborativa-menu-sidebar {
    flex: 0 0 280px;
    min-width: 220px;
    max-width: 320px;
    border-radius: 12px;
    background: #ffffff;
    border: 1px solid #d4d4d8;
  }

  .ia-colaborativa-menu-agent-list {
