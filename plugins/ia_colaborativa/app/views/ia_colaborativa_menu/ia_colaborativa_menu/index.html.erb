    gap: 12px;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid transparent;
    background: transparent;
    cursor: pointer;
    color: #111827;
    text-align: left;
    font-size: 14px;
  }

  .ia-colaborativa-menu-agent svg {
