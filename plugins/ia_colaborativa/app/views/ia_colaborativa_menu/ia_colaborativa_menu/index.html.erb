    flex-direction: column;
    gap: 16px;
    padding: 16px;
    height: 100%;
    justify-content: space-between;
  }

  .ia-colaborativa-menu-agent-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ia-colaborativa-menu-project-button {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid #e5e7eb;
    background: #ffffff;
    cursor: pointer;
    color: #111827;
    text-align: left;
    font-size: 14px;
    font-weight: 600;
  }

  .ia-colaborativa-menu-project-button:hover {
    background: #f3f4f6;
  }

  .ia-colaborativa-menu-agent {
