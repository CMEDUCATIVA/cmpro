  .ia-colaborativa-menu-active #ia-chat-messages button[style*="background: rgb(91, 70, 229)"] {
    background: #2563eb !important;
    border: 1px solid #2563eb !important;
    color: #ffffff !important;
    margin-left: 0 !important;
    margin-right: auto !important;
  }

  .ia-colaborativa-menu-active #ia-chat-messages button[style*="background: #5B46E5"] *,
  .ia-colaborativa-menu-active #ia-chat-messages button[style*="background: #5b46e5"] *,
  .ia-colaborativa-menu-active #ia-chat-messages button[style*="background: rgb(91, 70, 229)"] * {
    color: #ffffff !important;
  }

  .ia-colaborativa-menu-active #ia-chat-messages button[style*="background: #5B46E5"]:hover {
    background: #1d4ed8 !important;
    border-color: #1d4ed8 !important;
  }

  .ia-colaborativa-menu-active #ia-chat-messages a[style*="background:#5B46E5"],
  .ia-colaborativa-menu-active #ia-chat-messages a[style*="background: #5B46E5"],
  .ia-colaborativa-menu-active #ia-chat-messages a[style*="background:#5b46e5"],
  .ia-colaborativa-menu-active #ia-chat-messages a[style*="background: #5b46e5"] {
    background: #2563eb !important;
    border-color: #2563eb !important;
    color: #ffffff !important;
  }

  .ia-colaborativa-menu-active #ia-chat-messages a[style*="background:#5B46E5"]:hover,
  .ia-colaborativa-menu-active #ia-chat-messages a[style*="background: #5B46E5"]:hover,
  .ia-colaborativa-menu-active #ia-chat-messages a[style*="background:#5b46e5"]:hover,
  .ia-colaborativa-menu-active #ia-chat-messages a[style*="background: #5b46e5"]:hover {
    background: #1d4ed8 !important;
    border-color: #1d4ed8 !important;
    color: #ffffff !important;
  }

  .ia-colaborativa-menu-active #ia-agent-menu {
    background: #ffffff !important;
    border: 1px solid #e5e7eb !important;
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.12) !important;
  }

  .ia-colaborativa-menu-active #ia-agent-menu-button {
    background: transparent !important;
    border: none !important;
    color: #374151 !important;
  }

  .ia-colaborativa-menu-active #ia-agent-menu-button[ data-open="true" ] {
    background: #f3f4f6 !important;
  }

  .ia-colaborativa-menu-active #ia-agent-menu-label {
    color: #374151 !important;
  }

  .ia-colaborativa-menu-active #ia-agent-menu .ia-agent-option {
    color: #111827 !important;
    background: transparent !important;
  }

  .ia-colaborativa-menu-active #ia-agent-menu .ia-agent-option:hover {
    background: #f3f4f6 !important;
  }

  .ia-colaborativa-menu-active #ia-projects-button {
    color: #374151 !important;
  }

  .ia-colaborativa-menu-active #ia-chat-welcome h2 {
    color: #111827 !important;
  }

  .ia-colaborativa-menu-active #ia-chat-welcome p,
  .ia-colaborativa-menu-active #ia-chat-window .ia-message,
  .ia-colaborativa-menu-active #ia-chat-window .ia-message p {
    color: #374151 !important;
  }

  .ia-colaborativa-menu-active #ia-chat-messages,
  .ia-colaborativa-menu-active #ia-chat-messages * {
    color: #111827 !important;
  }

  .ia-colaborativa-menu-active #ia-chat-messages > div[style*="rgba(15, 23, 42, 0.15)"] {
    background: #f3f4f6 !important;
    box-shadow: none !important;
    border: 1px solid #e5e7eb !important;
    width: fit-content !important;
    max-width: 75% !important;
    margin-left: auto !important;
  }

  .ia-colaborativa-menu-active #ia-chat-messages > div[style*="rgba(15, 23, 42, 0.15)"] img {
    border-color: #e5e7eb !important;
  }

  .ia-colaborativa-menu-active #ia-chat-window[aria-hidden="true"] {
    display: flex !important;
  }

  @media (max-width: 1100px) {
    .ia-colaborativa-menu-layout {
      flex-direction: column;
    }

    .ia-colaborativa-menu-sidebar {
      width: 100%;
      max-width: none;
    }

    .ia-colaborativa-menu-thread {
      max-width: none;
    }
  }
</style>

<script nonce="<%= content_security_policy_script_nonce %>">
  (function () {
    var root = document.documentElement;
    var rootClass = "ia-colaborativa-menu-active";

    function clearMenuLayoutState() {
      if (!root) return;
      root.classList.remove(rootClass);
      root.style.removeProperty("--ia-colab-menu-offset");
      root.style.removeProperty("--ia-colab-menu-height");

      var chatWindow = document.getElementById("ia-chat-window");
      if (chatWindow && chatWindow.parentElement !== document.body) {
        document.body.appendChild(chatWindow);
      }
      if (chatWindow) {
        chatWindow.style.display = "none";
        chatWindow.setAttribute("aria-hidden", "true");
      }
    }

    function isMenuPageActive() {
      return !!document.querySelector(".ia-colaborativa-menu-page");
    }

    if (root && isMenuPageActive() && !root.classList.contains("ia-colaborativa-menu-active")) {
      root.classList.add("ia-colaborativa-menu-active");
    }

    function updateMenuOffset() {
      var header = document.querySelector("#header, .top-menu, .main-header");
      var headerHeight = header ? header.getBoundingClientRect().height : 0;
      var extra = 32;
      root.style.setProperty("--ia-colab-menu-offset", (headerHeight + extra) + "px");
    }

    function updateMenuHeight() {
      // Avoid forcing menu height from #content-body because OpenProject can
      // report a different rendered height and produce an extra vertical band.
      // Let CSS fallback use viewport-based formula with the computed offset.
      root.style.removeProperty("--ia-colab-menu-height");
    }

    function normalizeMainMenuResizer() {
      var resizer = document.querySelector("op-resizer.main-menu--resizer, .main-menu--resizer");
      if (!resizer) return;
      resizer.style.top = "55px";
      resizer.style.bottom = "0";
      resizer.style.height = "auto";
      resizer.style.maxHeight = "calc(100vh - 55px)";
    }

    function moveChatWindow() {
      var container = document.querySelector(".ia-colaborativa-menu-thread");
      var chatWindow = document.getElementById("ia-chat-window");
      if (!container || !chatWindow) {
        return false;
      }
      if (chatWindow.parentElement !== container) {
        container.appendChild(chatWindow);
      }
      chatWindow.style.display = "flex";
      chatWindow.setAttribute("aria-hidden", "false");
      if (window.openIaChat) {
        window.openIaChat();
      }
      normalizeEmptyChatState();
      return true;
    }

    function normalizeEmptyChatState() {
      var list = document.getElementById("ia-chat-messages");
      var welcome = document.getElementById("ia-chat-welcome");
      if (!list || !welcome) return;

      // Detect actual rendered content, not just empty child containers.
      var hasMessages = Array.prototype.some.call(list.children || [], function (child) {
        if (!child) return false;
        if (child.offsetParent === null) return false;
        var text = (child.textContent || "").trim();
        if (text.length > 0) return true;
        return !!child.querySelector("img, table, button, a, svg, pre, code");
      });

      if (!hasMessages) {
        list.style.display = "none";
        welcome.style.display = "flex";
      } else {
        list.style.display = "flex";
        welcome.style.display = "none";
      }
    }

    function bindChatStateObserver() {
      var list = document.getElementById("ia-chat-messages");
      if (!list || list.dataset.iaMenuObserved === "true") return;

      var observer = new MutationObserver(function () {
        normalizeEmptyChatState();
      });
      observer.observe(list, { childList: true, subtree: true, attributes: true });
      list.dataset.iaMenuObserved = "true";
    }

    function ensureChatWindow(attemptsLeft) {
      if (moveChatWindow() || attemptsLeft <= 0) {
        return;
      }
      requestAnimationFrame(function () {
        ensureChatWindow(attemptsLeft - 1);
      });
    }

    function syncAgentSidebar() {
      var current = window.currentAgent || "sara";
      var buttons = document.querySelectorAll(".ia-colaborativa-menu-agent");
      buttons.forEach(function (button) {
        var isActive = button.getAttribute("data-agent") === current;
        button.classList.toggle("is-active", isActive);
      });
    }

    function bindAgentSidebar() {
      var buttons = document.querySelectorAll(".ia-colaborativa-menu-agent");
      buttons.forEach(function (button) {
        if (button.dataset && button.dataset.iaMenuBound === "true") {
          return;
        }
        button.addEventListener("click", function () {
          var agent = button.getAttribute("data-agent") || "sara";
          console.log("[IA Menu] click agent:", agent);
          window.currentAgent = agent;
          if (window.onAgentChange) {
            window.onAgentChange(agent);
          } else {
            window.currentAgent = agent;
          }
          syncAgentSidebar();
          if (agent === "cde") {
            console.log("[IA Menu] cde selected, opening project search");
            openProjectModalOnce();
          }
        });
        if (button.dataset) {
          button.dataset.iaMenuBound = "true";
        }
      });
      syncAgentSidebar();
    }

    function bindProjectButton() {
      var button = document.querySelector(".ia-colaborativa-menu-project-button");
      if (!button) return;
      if (button.dataset && button.dataset.iaMenuBound === "true") {
        return;
      }
      button.addEventListener("click", function () {
        console.log("[IA Menu] click project selector");
        window.currentAgent = "cde";
        if (window.onAgentChange) {
          window.onAgentChange("cde");
        } else {
          window.currentAgent = "cde";
        }
        syncAgentSidebar();
        openProjectModalOnce();
      });
      if (button.dataset) {
        button.dataset.iaMenuBound = "true";
      }
    }

    function patchMindmapButton() {
      if (!window.attachMindmapButton || window.attachMindmapButton.__iaMenuPatched) {
        return;
      }
      var original = window.attachMindmapButton;
      window.attachMindmapButton = function (aiNode, responseText) {
        original(aiNode, responseText);
        if (!aiNode) return;
        var mindmapButton = Array.prototype.find.call(
          aiNode.querySelectorAll("button"),
          function (btn) { return btn.textContent && btn.textContent.trim() === "Mapa mental"; }
        );
        if (!mindmapButton) return;
        var actionIcon = aiNode.querySelector('button[title="Copiar respuesta"], button[title="Regenerar respuesta"]');
        var actionsRow = actionIcon ? actionIcon.parentElement : null;
        if (actionsRow && actionsRow !== mindmapButton.parentElement) {
          actionsRow.appendChild(mindmapButton);
          var oldRow = mindmapButton.parentElement;
          if (oldRow && oldRow !== actionsRow && oldRow.children.length === 0) {
            oldRow.remove();
          }
        }
      };
      window.attachMindmapButton.__iaMenuPatched = true;
    }

    function patchOnAgentChange() {
      if (!window.onAgentChange || window.onAgentChange.__iaMenuPatched) {
        return;
      }
      var original = window.onAgentChange;
      window.onAgentChange = function (agentType) {
        console.log("[IA Menu] onAgentChange:", agentType);
        window.currentAgent = agentType || "docs";
        original(agentType);
        if (agentType === "cde" && !window.selectedProject) {
          console.log("[IA Menu] onAgentChange cde without project, opening search");
          openProjectModalOnce();
        }
      };
      window.onAgentChange.__iaMenuPatched = true;
    }

    function openProjectModalOnce() {
      var modal = document.getElementById("ia-projects-search-modal");
      if (window.__iaMenuProjectModalOpen && modal && modal.style.display === "flex") {
        return;
      }
      window.__iaMenuProjectModalOpen = true;
      if (window.openProjectsSearchModal) {
        console.log("[IA Menu] openProjectsSearchModal");
        window.openProjectsSearchModal();
      }
      if (modal) {
        setTimeout(function () {
          if (modal.style.display !== "flex") {
            console.log("[IA Menu] force modal display");
            modal.style.display = "flex";
          }
        }, 50);
      }
    }

    function patchCloseProjectsModal() {
      if (!window.closeProjectsSearchModal || window.closeProjectsSearchModal.__iaMenuPatched) {
        return;
      }
      var original = window.closeProjectsSearchModal;
      window.closeProjectsSearchModal = function () {
        window.__iaMenuProjectModalOpen = false;
        return original.apply(this, arguments);
      };
      window.closeProjectsSearchModal.__iaMenuPatched = true;
    }

    document.addEventListener("DOMContentLoaded", function () {
      if (!isMenuPageActive()) {
        clearMenuLayoutState();
        return;
      }
      updateMenuOffset();
      updateMenuHeight();
      normalizeMainMenuResizer();
      ensureChatWindow(10);
      normalizeEmptyChatState();
      bindChatStateObserver();
      bindAgentSidebar();
      bindProjectButton();
      patchMindmapButton();
      patchOnAgentChange();
      patchCloseProjectsModal();
    });
    document.addEventListener("turbo:load", function () {
      if (!isMenuPageActive()) {
        clearMenuLayoutState();
        return;
      }
      updateMenuOffset();
      updateMenuHeight();
      normalizeMainMenuResizer();
      ensureChatWindow(10);
      normalizeEmptyChatState();
      bindChatStateObserver();
      bindAgentSidebar();
      bindProjectButton();
      patchMindmapButton();
      patchOnAgentChange();
      patchCloseProjectsModal();
    });
    window.addEventListener("resize", function () {
      if (!isMenuPageActive()) return;
      updateMenuOffset();
      updateMenuHeight();
      normalizeMainMenuResizer();
    });

    // Important with Turbo cache/navigation: clean global styles when leaving this view
    document.addEventListener("turbo:before-cache", clearMenuLayoutState);
    document.addEventListener("turbo:before-visit", clearMenuLayoutState);
    document.addEventListener("turbo:render", function () {
      if (!isMenuPageActive()) {
        clearMenuLayoutState();
      }
    });
    window.addEventListener("beforeunload", clearMenuLayoutState);
  })();
</script>
