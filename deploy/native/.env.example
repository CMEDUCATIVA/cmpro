# Copy to /etc/openproject-custom/openproject.env on the server.

APP_NAME=openproject-custom
APP_USER=openproject
APP_PATH=/opt/openproject-custom
APP_DATA_PATH=/var/openproject-custom/assets
OPENPROJECT_BASE_VERSION=16.1.1
POSTGRES_VERSION=13
POSTGRES_CURRENT_MINOR=13.21

RAILS_ENV=production
RACK_ENV=production
HOST=127.0.0.1
PORT=8080
SECRET_KEY_BASE=CHANGE_ME_generate_with_openssl_rand_hex_64

DATABASE_URL=postgres://openproject:CHANGE_ME_database_password@127.0.0.1:5432/openproject
POSTGRES_STATEMENT_TIMEOUT=90s

OPENPROJECT_HOST__NAME=localhost
OPENPROJECT_HTTPS=false
OPENPROJECT_EDITION=standard
OPENPROJECT_INSTALLATION__TYPE=manual
OPENPROJECT_ATTACHMENTS__STORAGE__PATH=/var/openproject-custom/assets/files
OPENPROJECT_RAILS__CACHE__STORE=file_store
OPENPROJECT_RAILS__RELATIVE__URL__ROOT=
OPENPROJECT_ENABLE__INTERNAL__ASSETS__SERVER=true
OPENPROJECT_WEB_WORKERS=2
OPENPROJECT_WEB_MAX__THREADS=8
OPENPROJECT_WEB_MIN__THREADS=4

# IA colaborativa. Keep real keys only on the server.
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_MODEL=google/gemini-2.5-flash-lite
OPENAI_VISION_MODEL=google/gemini-2.5-flash-image
LIGHTRAG_URL=
LIGHTRAG_API_KEY=
MCP_SERVER_URL=
MCP_SERVER_USERNAME=
MCP_SERVER_PASSWORD=
OPENPROJECT_IA_PROMPT_PASSWORD=

# Optional SMTP
OPENPROJECT_EMAIL__DELIVERY__METHOD=test
OPENPROJECT_SMTP__ADDRESS=
OPENPROJECT_SMTP__PORT=587
OPENPROJECT_SMTP__DOMAIN=
OPENPROJECT_SMTP__USER__NAME=
OPENPROJECT_SMTP__PASSWORD=
OPENPROJECT_SMTP__AUTHENTICATION=plain
OPENPROJECT_SMTP__ENABLE__STARTTLS__AUTO=true
