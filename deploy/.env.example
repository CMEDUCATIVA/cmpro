# Copy this file to deploy/.env and change every value marked CHANGE_ME.

COMPOSE_PROJECT_NAME=openproject_custom

OPENPROJECT_HOST=localhost
OPENPROJECT_HTTPS=false
OPENPROJECT_SECRET_KEY_BASE=CHANGE_ME_generate_with_openssl_rand_hex_64
OPENPROJECT_EDITION=standard
OPENPROJECT_WEB_WORKERS=2
OPENPROJECT_WEB_MAX_THREADS=8
OPENPROJECT_WEB_MIN_THREADS=4

POSTGRES_DB=openproject
POSTGRES_USER=openproject
POSTGRES_PASSWORD=CHANGE_ME_database_password

MEMCACHE_SERVERS=cache:11211

# IA colaborativa. Keep keys out of Git; set them in deploy/.env on each server.
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_MODEL=google/gemini-2.5-flash-lite
OPENAI_VISION_MODEL=google/gemini-2.5-flash-image
LIGHTRAG_URL=
LIGHTRAG_API_KEY=
MCP_SERVER_URL=
MCP_SERVER_USERNAME=
MCP_SERVER_PASSWORD=
OPENPROJECT_IA_PROMPT_PASSWORD=

# Optional email settings. Leave delivery as test until SMTP is configured.
OPENPROJECT_EMAIL__DELIVERY__METHOD=test
OPENPROJECT_SMTP__ADDRESS=
OPENPROJECT_SMTP__PORT=587
OPENPROJECT_SMTP__DOMAIN=
OPENPROJECT_SMTP__USER__NAME=
OPENPROJECT_SMTP__PASSWORD=
OPENPROJECT_SMTP__AUTHENTICATION=plain
OPENPROJECT_SMTP__ENABLE__STARTTLS__AUTO=true
