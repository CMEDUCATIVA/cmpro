<% content_for :header_tags do %>
  <% provision_gon_for_ifc_model(@ifc_models, @shown_model_ids) %>
<% end %>

<% unconverted = @shown_ifc_models.reject(&:converted?) %>

<% if unconverted.any? %>
  <%= render partial: "unconverted_notice", locals: { unconverted: unconverted } %>
<% end %>

<% auto_refresh_ids = @ifc_models.select { |model| model.pending? || model.processing? }.map(&:id) %>
<% if auto_refresh_ids.any? %>
  <script>
    (function() {
      const pendingIds = <%= raw(auto_refresh_ids.to_json) %>;
      const progressUrl = "<%= progress_bcf_project_ifc_models_path(@project, format: :json) %>";
      if (!pendingIds.length) return;

      let tries = 0;
      const maxTries = 120; // ~4 minutes at 2s
      const timer = window.setInterval(async () => {
        tries += 1;
        if (tries > maxTries) {
          window.clearInterval(timer);
          return;
        }

        try {
          const url = `${progressUrl}?ids=${pendingIds.join(",")}`;
          const response = await fetch(url, { credentials: "same-origin" });
          if (!response.ok) return;
          const payload = await response.json();
          const models = Array.isArray(payload?.models) ? payload.models : [];
          if (!models.length) return;

          const allDone = models.every((model) => {
            const status = (model?.status || "").toString();
            return status !== "pending" && status !== "processing";
          });

          if (allDone) {
            window.clearInterval(timer);
            window.location.reload();
          }
        } catch (_e) {
          // keep polling
        }
      }, 2000);
    })();
  </script>
<% end %>

<openproject-base></openproject-base>
